# ──────────────────────────────────────────────
# argus-ai — Environment Variables
# ──────────────────────────────────────────────

# Primary LLM — DeepSeek V3 (required for /chat to work)
DEEPSEEK_API_KEY=          # required — set your DeepSeek API key here
DEEPSEEK_URL=https://api.deepseek.com/v1
PORT=3000
NODE_ENV=development

# Connectors — leave empty to use offline/stub mode
PROMETHEUS_URL=
LOKI_URL=
ARGOCD_URL=
ARGOCD_TOKEN=
KUBECONFIG=
