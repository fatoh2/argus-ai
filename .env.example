# Primary LLM — DeepSeek V3 (recommended, ~$1-3/month, no rate limits)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# Optional: override model or URL
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_URL=https://api.deepseek.com/chat/completions

# Fallback LLM — Gemini (optional)
GEMINI_API_KEY=

# Optional connectors — service works without these (graceful degradation)
# K8s / Prometheus
KUBECONFIG_BASE64=         # base64-encoded kubeconfig
PROMETHEUS_URL=http://localhost:9090

# Loki
LOKI_URL=http://localhost:3100

# ArgoCD
ARGOCD_SERVER=localhost:8080
ARGOCD_TOKEN=

PORT=3000
NODE_ENV=development
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=50000
