# ──────────────────────────────────────────────
# argus-ai — Environment Variables
# ──────────────────────────────────────────────

# Primary LLM — DeepSeek V3 (required for /chat to work)
DEEPSEEK_API_KEY=your-deepseek-api-key-here  # required — set your DeepSeek API key here
DEEPSEEK_URL=https://api.deepseek.com/chat/completions
PORT=3000
NODE_ENV=development

# LLM configuration
LLM_TIMEOUT_MS=30000       # request timeout in milliseconds
LLM_MAX_TOKENS=50000       # max tokens for LLM response

# Redis (required for queue/job processing)
REDIS_URL=redis://localhost:6379

# Connectors — leave empty to use offline/stub mode
PROMETHEUS_URL=http://localhost:9090  # default — change to your Prometheus server URL
LOKI_URL=                            # Loki URL (optional, leave empty for offline mode)
ARGOCD_URL=                          # ArgoCD server URL (optional, leave empty for offline mode)
ARGOCD_TOKEN=                        # ArgoCD auth token (optional)
KUBECONFIG=                          # Path to kubeconfig file (optional, leave empty for offline mode)
